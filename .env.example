# Llama Runner MIMO - Environment Variables
# Copy this file to .env and fill in the values.

# API Key for orchestrator authentication
# ORCHESTRATOR_API_KEY=your_secret_key_here

# ERP client API key
# ERP_API_KEY=erp_secret_key_here

# CORS allowed origins (set in runner_config.json "allowed_origins" field)
# For IP access: ["192.168.1.100"] or ["*"] for all origins
# For domain access: ["https://myapp.com"]

# Flask session secret (auto-generated if not set)
# FLASK_SECRET_KEY=your_random_secret_key_here
